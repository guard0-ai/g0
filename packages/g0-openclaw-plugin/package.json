{
  "name": "@guard0/openclaw-plugin",
  "version": "1.0.0",
  "description": "g0 security plugin for OpenClaw gateway — tool call logging, injection detection, PII scanning",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "openclaw": {
    "extensions": ["./src/index.ts"]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "files": ["dist"],
  "license": "MIT",
  "keywords": ["openclaw", "plugin", "security", "guard0", "g0"]
}
